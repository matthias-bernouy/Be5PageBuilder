{
    "compilerOptions": {
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleResolution": "bundler",
        "moduleDetection": "force",

        "allowJs": true,
        "verbatimModuleSyntax": true,
        "esModuleInterop": true,

        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,

        "types": ["bun-types"],

        "noEmit": true
    },
    "include": ["App.ts", "providers/**/*.ts"]
}
