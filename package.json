{
    "name": "be5-pagebuilder",
    "version": "0.0.1",
    "description": "Modular CMS built on Web Components with an inline visual editing system. Bun + MongoDB.",
    "license": "UNLICENSED",
    "type": "module",
    "main": "./index.ts",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "bun": "./index.ts",
            "default": "./index.ts"
        }
    },
    "files": [
        "index.ts",
        "build.ts",
        "src/",
        "w13c/",
        "types/",
        "dist/",
        "tsconfig.json",
        "README.md",
        "CLAUDE.md"
    ],
    "scripts": {
        "dev": "bun --hot run App.ts",
        "build": "bun run build.ts",
        "typecheck": "bun x tsc --noEmit",
        "prepublishOnly": "bun run build"
    },
    
    "devDependencies": {
        "@types/bun": "latest",
        "bun-types": "^1.3.11",
        "be5-interfaces": "link:be5-interfaces",
        "typescript": "^5.9.3"
    },

    "peerDependencies": {
        "be5-interfaces": "*",
        "typescript": "^5.9.3"
    },

    "dependencies": {
        "linkedom": "^0.18.12",
        "mongodb": "~7.1.1",
        "sharp": "^0.34.5"
    },

    "engines": {
        "bun": ">=1.3.0"
    }
}
