{
    "name": "@bernouy/cms",
    "version": "1.0.2",
    "description": "Modular CMS built on Web Components with an inline visual editing system. Bun + MongoDB.",
    "license": "UNLICENSED",
    "type": "module",
    "main": "./index.ts",
    "types": "./dist/index.d.ts",
    "bin": {
        "p9r": "./src/cli/index.ts"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "bun": "./index.ts",
            "default": "./index.ts"
        },
        "./component": {
            "bun": "./component.ts",
            "default": "./component.ts"
        },
        "./editor": {
            "bun": "./editor.ts",
            "default": "./editor.ts"
        }
    },
    "files": [
        "index.ts",
        "component.ts",
        "editor.ts",
        "build.ts",
        "src/",
        "types/",
        "dist/",
        ".claude/skills/",
        "tsconfig.json",
        "README.md",
        "CLAUDE.md"
    ],
    "scripts": {
        "dev": "bun --hot run App.ts",
        "build": "bun run build.ts",
        "typecheck": "bun x tsc --noEmit",
        "test": "bun test",
        "perf": "bun run tests/perf/run.ts",
        "prepublishOnly": "bun run build"
    },
    "devDependencies": {
        "@bernouy/socle": "1.0.1",
        "@happy-dom/global-registrator": "^20.8.9",
        "@types/bun": "latest",
        "bun-types": "^1.3.11",
        "happy-dom": "^20.8.9",
        "playwright": "^1.59.1",
        "typescript": "^5.9.3"
    },
    "peerDependencies": {
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "linkedom": "^0.18.12",
        "mongodb": "~7.1.1",
        "sharp": "^0.34.5"
    },
    "engines": {
        "bun": ">=1.3.0"
    }
}
