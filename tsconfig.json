{
	"compilerOptions": {
		"lib": ["ESNext", "DOM"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"moduleResolution": "bundler",

		"allowJs": true,
		"verbatimModuleSyntax": true,
		"esModuleInterop": true,

		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,

		"declaration": true,
		"emitDeclarationOnly": true,
		"declarationMap": false,

		"experimentalDecorators": true,

		"outDir": "dist",
		"rootDir": ".",
		"baseUrl": ".",

		"paths": {
			"@bernouy/pagebuilder": ["client.ts", "index.ts"]
		}

	},

	"include": [
		"src/**/*.ts",
		"w13c/**/*.ts",
        "App.ts",
        "index.ts",
        "build.ts",
        "src/cli/CLI_importBloc.ts",
		"types/**/*.d.ts",
		"types/editor-attributs.ts"
	]

}
